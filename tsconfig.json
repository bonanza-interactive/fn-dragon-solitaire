{
  "compilerOptions": {
    "noEmit": false,
    "allowJs": false,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2019",
    "lib": ["dom", "es2019"],
    "declaration": true,
    "removeComments": true,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "noImplicitReturns": true,
    "strict": true,
    "noImplicitAny": true,
    "downlevelIteration": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src", "ap/ap.ts", "ap/particle.ts", "ap/ap-overlay.ts"],
  "exclude": ["node_modules", "dist"],
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node"
    }
  }
}
