      "pays_html": "<style>.rgk-header {text-align: center;}.rgk-pays__description {display: flex;justify-content: center;text-align: center;width: 100%;margin-top: 1em;}.rgk-pays__group {display: flex;justify-content: center;align-items: start;text-align: center;gap: 2em;margin-top: 2em;margin-bottom: 2em;flex-wrap: wrap;}.rgk-pays__group-end-align {display: flex;justify-content: center;align-items: end;text-align: center;gap: 2em;margin-top: 2em;margin-bottom: 2em;flex-wrap: wrap;}.rgk-pays__symbol {display: flex;flex-direction: column;justify-content: end;align-items: center;gap: 1em;}.rgk-pays__symbol_horizontal {display: flex;flex-direction: row;flex-wrap: wrap;justify-content: end;align-items: center;gap: 1em;justify-content: center;}.rgk-pays__payout {display: grid;grid-template-columns: 2em auto;text-align: left;white-space: nowrap;}.rgk-pays__payout_horizontal {display: grid;grid-template-columns: 1em minmax(4em, max-content) auto;text-align: start;white-space: nowrap;column-gap: 0.4em;}.rgk-pays__count {grid-column-start: 1;grid-column-end: span 1;}.rgk-pays__winfactor {font-weight: bold;grid-column-start: 2;grid-column-end: span 2;}.rgk-pays__winfactor_horizontal {font-weight: bold;}.rgk-pays__image-content {position: relative;}.rgk-pays__image-centered-text {position: absolute;left: 50%;top: 50%;transform: translate(-50%, -50%);}.rgk-pays__image.huge {width: 15em;max-width: 100%;object-fit: contain;}.rgk-pays__image.big {width: 10em;max-width: 100%;object-fit: contain;}.rgk-pays__image.medium {width: 8em;max-width: 100%;object-fit: contain;}.rgk-pays__image.small {width: 5em;max-width: 100%;object-fit: contain;}.rgk-paylines__section {display: flex;flex-direction: column;flex-wrap: wrap;justify-content: center;text-align: center;width: 100%;margin-top: 1em;}.rgk-paylines__image img {width: 10em;max-width: 100%;height: auto;}.rgk-paylines__image.small {width: 10em;max-width: 100%;height: auto;}.rgk-paylines__image.medium {width: 17em;max-width: 100%;height: auto;}.rgk-paylines__image.big {width: 30em;max-width: 100%;height: auto;}.rgk-paylines {display: flex;flex-direction: row;flex-wrap: wrap;justify-content: center;text-align: center;width: 100%;}.rgk-payline {display: inline-block;margin: 0.5em 0.5em 0.5em 0.5em;}.rgk-payline__cell {width: 1em;height: 1em;background-color: #909090;border-style: solid;border-color: black;border-width: thin;}.rgk-payline__cell--active {background-color: #FFD104;}</style><div class='rgk-header'><h1>{pays_header}</h1></div><div class='rgk-pays'><div class='rgk-pays__description'><p>{help_paytable_description}</p></div><div class='rgk-pays__group'><table class='rgk-pays__paytable'><tbody><tr><th scope=\"row\" rowspan=\"2\">{help_paytable_selected}</th><th scope=\"col\" colspan=\"6\">{help_paytable_hits}</th></tr><tr><th scope=\"col\">1</th><th scope=\"col\">2</th><th scope=\"col\">3</th><th scope=\"col\">4</th><th scope=\"col\">5</th><th scope=\"col\">6</th></tr><tr><th scope=\"row\">2</th><th>0.5x</th><th>6.5x</th><th>—</th><th>—</th><th>—</th><th>—</th></tr><tr><th scope=\"row\">3</th><th>—</th><th>3x</th><th>13.5x</th><th>—</th><th>—</th><th>—</th></tr><tr><th scope=\"row\">4</th><th>—</th><th>1.5x</th><th>5x</th><th>35x</th><th>—</th><th>—</th></tr><tr><th scope=\"row\">5</th><th>—</th><th>0.5x</th><th>4x</th><th>9x</th><th>55x</th><th>—</th></tr><tr><th scope=\"row\">6</th><th>—</th><th>0.5x</th><th>1.5x</th><th>7x</th><th>30x</th><th>200x</th></tr></tbody></table></div><div class='rgk-pays__description'><p>{help_paytable_freespins_description}</p></div><div class='rgk-pays__group'><table class='rgk-pays__paytable'><tbody><tr><th scope=\"col\">{help_paytable_hits}</th><th scope=\"col\">{paytable_win}</th></tr><th>1</th><th>0.5x</th></tr><th>2</th><th>1x</th></tr><th>3</th><th>5x</th></tr><th>4</th><th>20x</th></tr></tbody></table></div></div>",
      "help_html": "<style>.rgk-help__section {display: flex;flex-direction: column;flex-wrap: wrap;justify-content: center;text-align: center;width: 100%;margin-top: 1em;}.rgk-help__content__description {width: 100%;margin-top: 1em;}.rgk-help__content__description-paragraph {max-width: 100%;width: 100%;text-align: start;}.rgk-help__header {margin-top: 2em;margin-bottom: 1em;}.rgk-help__subheader {margin-top: 1em;}.rgk-help__section img {width: 10em;max-width: 100%;height: auto;}.rgk-help__image-content {position: relative;display: flex;flex-flow: column;align-items: center;}.rgk-help__image-centered-text {position: absolute;left: 50%;top: 50%;transform: translate(-50%, -50%);}.rgk-help__image.small {width: 10em;max-width: 100%;height: auto;}.rgk-help__image.medium {width: 17em;max-width: 100%;height: auto;}.rgk-help__image.big {width: 30em;max-width: 100%;height: auto;}.rgk-help__payouts {display: flex;flex-direction: column;justify-content: center;align-items: center;margin-top: 1em;width: 100%;}.rgk-help__payouts_with_img {display: flex;flex-wrap: wrap;align-items: center;gap: 0.5em;justify-content: center;}.rgk-help__payout {width: 100%;text-align: start;}.rgk-help__payout-image {flex: 0 0 7em;height: auto;}.rgk-help__payout-texts {flex: 1;min-width: 20em;}.rgk-help__payout-text {width: 100%;margin-right: 7em;}.rgk-help__payout__count {margin-right: 5px;}.rgk-help__payout__text {margin-right: 5px;}.rgk-help__payout__winfactor {font-weight: bold;}.rgk-pays__paytable {border-collapse: collapse;border: 1px solid rgb(140 140 140);display: flex;font-weight: bold;overflow-x: auto;}.rgk-pays__paytable th,.rgk-pays__paytable td {border: 1px solid rgb(130 130 130);padding: 8px 10px;}.rgk-pays__paytable th:first-child {text-align: left;}.rgk-pays__paytable th[scope=\"col\"] {background-color: #454343;color: #fff;}.rgk-pays__paytable th[scope=\"row\"] {background-color: #313131;}.rgk-pays__group {display: flex;justify-content: center;align-items: start;text-align: center;g