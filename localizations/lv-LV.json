      "help_html": "<style>.rgk-help__section {display: flex;flex-direction: column;flex-wrap: wrap;justify-content: center;text-align: center;width: 100%;margin-top: 1em;}.rgk-help__content__description {width: 100%;margin-top: 1em;}.rgk-help__content__description-paragraph {max-width: 100%;width: 100%;text-align: start;}.rgk-help__header {margin-top: 2em;margin-bottom: 1em;}.rgk-help__subheader {margin-top: 1em;}.rgk-help__section img {width: 10em;max-width: 100%;height: auto;}.rgk-help__image-content {position: relative;display: flex;flex-flow: column;align-items: center;}.rgk-help__image-centered-text {position: absolute;left: 50%;top: 50%;transform: translate(-50%, -50%);}.rgk-help__image.small {width: 10em;max-width: 100%;height: auto;}.rgk-help__image.medium {width: 17em;max-width: 100%;height: auto;}.rgk-help__image.big {width: 30em;max-width: 100%;height: auto;}.rgk-help__payouts {display: flex;flex-direction: column;justify-content: center;align-items: center;margin-top: 1em;width: 100%;}.rgk-help__payouts_with_img {display: flex;flex-wrap: wrap;align-items: center;gap: 0.5em;justify-content: center;}.rgk-help__payout {width: 100%;text-align: start;}.rgk-help__payout-image {flex: 0 0 7em;height: auto;}.rgk-help__payout-texts {flex: 1;min-width: 20em;}.rgk-help__payout-text {width: 100%;margin-right: 7em;}.rgk-help__payout__count {margin-right: 5px;}.rgk-help__payout__text {margin-right: 5px;}.rgk-help__payout__winfactor {font-weight: bold;}.rgk-pays__paytable {border-collapse: collapse;border: 1px solid rgb(140 140 140);display: flex;font-weight: bold;overflow-x: auto;}.rgk-pays__paytable th,.rgk-pays__paytable td {border: 1px solid rgb(130 130 130);padding: 8px 10px;}.rgk-pays__paytable th:first-child {text-align: left;}.rgk-pays__paytable th[scope=\"col\"] {background-color: #454343;color: #fff;}.rgk-pays__paytable th[scope=\"row\"] {background-color: #313131;}.rgk-pays__group {display: flex;justify-content: center;align-items: start;text-align: center;g