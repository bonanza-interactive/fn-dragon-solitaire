  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "ts-node server/main.ts",
    "start-server": "java -jar server/runtime/egs.jar --spring.profiles.active=dev --backendFile=server/runtime/backend.jar  --variantConfig=server/runtime/variantConfig.json --server.port=4567",
    "start-egm": "java -jar server/runtime/egs.jar --spring.profiles.active=dev --backendFile=server/runtime/backend.jar  --variantConfig=server/runtime/variantConfig.json --operatorConfig=server/runtime/operatorConfigPS.json --egm=true",
    "prettier:check": "yarn prettier --check \"./src/**/*.ts\"",
    "prettier:write": "yarn prettier --write \"./src/**/*.ts\"",
    "sort-imports": "format-imports ./src/",
    "sync-egs": "ts-node -T server/dl-egs.ts -ebvu server/runtime",
    "lint": "eslint \"./src/**/*.ts\"",
    "lint:fix": "eslint --fix \"./src/**/*.ts\"",
    "test": "echo \"no tests configured\"",
    "prepare": "husky install",
    "ap": "ts-node ap/ap.ts",
    "ap-all": "ts-node ap/ap.ts --all",
    "ap-watch": "ts-node ap/ap.ts --daemon",
    "ap-release": "ts-node ap/ap.ts --release",
    "wip-site-assets": "ts-node ap/ap.ts --fast --all && rm -rf release && mv dev-release release",
    "release-check": "ap-check missing release && ap-check formats release && ap-check spine-pma release",
    "build-intro": "ts-node script/intro-builder.ts"
  },
  "devDependencies": {
    "@apila/asset-pipeline": "7.4.0",
    "@apila/casino-frame": "7.0.0",
    "@apila/casino-loader": "7.0.0",
