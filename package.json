    "@apila/engine": "28.1.1",
    "@apila/game-libraries": "3.3.0",
    "@apila/localization-tools": "^1.14.1",
    "@apila/particle-runtime": "3.0.0",
    "@apila/reel-library": "1.0.0",
    "@apila/slot-machine": "4.1.1",
    "@swc/cli": "0.3.12",
    "@swc/core": "1.4.17",
    "@swc/helpers": "0.5.11",
    "@types/node": "20.9.3",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "curve-interpolator": "3.3.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "fork-ts-checker-webpack-plugin": "9.0.2",
    "husky": "8.0.3",
    "lint-staged": "15.5.0",
    "maxrects-packer": "2.7.3",
    "minimist": "1.2.8",
    "nodemon": "3.1.4",
    "prettier": "^3.3.3",
    "superstruct": "1.0.3",
    "swc-loader": "^0.2.6",
    "ts-node": "10.9.1",
    "tslib": "^2.6.2",
    "typescript": "=5.1.3"
  },
